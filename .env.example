# ============================================
# Prelease Canada — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# --- Application ---
APP_NAME="Prelease Canada"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/production
FRONTEND_URL=https://your-app.vercel.app

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (AWS RDS MySQL) ---
DB_CONNECTION=mysql
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_DATABASE=prelease
DB_USERNAME=admin
DB_PASSWORD=your-rds-password

# --- Cache & Sessions (use array for Lambda) ---
BROADCAST_DRIVER=pusher
CACHE_DRIVER=array
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=sqs
SESSION_DRIVER=array
SESSION_LIFETIME=120

# --- AWS S3 (file storage: property images, documents) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=prelease-storage-production
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- AWS SQS (background jobs: emails, notifications) ---
SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/your-account-id
SQS_QUEUE=prelease-api-production-jobs
SQS_SUFFIX=
SQS_REGION=us-east-1

# --- Mail (transactional emails via SMTP) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD="your-gmail-app-password"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your-email@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Stripe (payments) ---
STRIPE_KEY=pk_live_your-stripe-publishable-key
STRIPE_SECRET=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=${APP_URL}/api/auth/google/callback

# --- Facebook OAuth ---
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# --- Apple Sign In ---
APPLE_CLIENT_ID=your-apple-service-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id

# --- Pusher (real-time chat) ---
PUSHER_APP_ID=your-pusher-app-id
PUSHER_APP_KEY=your-pusher-app-key
PUSHER_APP_SECRET=your-pusher-app-secret
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# --- Passport (OAuth tokens) ---
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# --- Groq (LLM fallback) ---
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Twilio (SMS and Phone for Virtual Assistant) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_API_KEY_SID=your-twilio-api-key-sid
TWILIO_API_KEY_SECRET=your-twilio-api-key-secret

# --- KIRI Engine (3D Gaussian Splatting) ---
KIRI_API_KEY=your-kiri-api-key
KIRI_WEBHOOK_SECRET=
