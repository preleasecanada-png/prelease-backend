# ============================================
# Prelease Canada — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# --- Application ---
APP_NAME="Prelease Canada"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/production
FRONTEND_URL=https://your-app.vercel.app

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (AWS RDS MySQL) ---
DB_CONNECTION=mysql
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_DATABASE=prelease
DB_USERNAME=admin
DB_PASSWORD=your-rds-password

# --- Cache & Sessions (use array for Lambda) ---
BROADCAST_DRIVER=pusher
CACHE_DRIVER=array
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=sqs
SESSION_DRIVER=array
SESSION_LIFETIME=120

# --- AWS S3 (file storage: property images, documents) ---
AWS_ACCESS_KEY_ID=AKIA26OD3PQJY2UMTAHH
AWS_SECRET_ACCESS_KEY=AKIA26OD3PQJY2UMTAHH,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
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=prelease-storage-production
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- AWS SQS (background jobs: emails, notifications) ---
SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/752566893587
SQS_QUEUE=prelease-api-production-jobs
SQS_SUFFIX=
SQS_REGION=us-east-1

# --- Mailgun (transactional emails) ---
MAIL_MAILER=mailgun
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_SECRET=your-mailgun-api-key
MAILGUN_ENDPOINT=api.mailgun.net
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Stripe (payments) ---
STRIPE_KEY=pk_live_your-stripe-publishable-key
STRIPE_SECRET=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=${APP_URL}/api/auth/google/callback

# --- Facebook OAuth ---
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# --- Apple Sign In ---
APPLE_CLIENT_ID=your-apple-service-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id

# --- Frontend URL ---
FRONTEND_URL=https://www.preleasecanada.ca

# --- Google Gemini (AI Assistant — free tier) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Pusher (real-time chat) ---
PUSHER_APP_ID=your-pusher-app-id
PUSHER_APP_KEY=your-pusher-app-key
PUSHER_APP_SECRET=your-pusher-app-secret
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=us2

# --- Passport (OAuth tokens) ---
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
